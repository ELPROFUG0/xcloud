{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xCloud",
  "version": "0.1.0",
  "identifier": "com.xcloud.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "xCloud",
        "width": 1440,
        "height": 900,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "trafficLightPosition": { "x": 20, "y": 28 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["xcloud-agent"],
        "name": "xCloud Agent Package",
        "description": "Portable xCloud agent package",
        "role": "Editor",
        "rank": "Owner",
        "mimeType": "application/vnd.xcloud.agent+zip",
        "exportedType": {
          "identifier": "com.xcloud.agent-package",
          "conformsTo": ["public.zip-archive", "public.data"]
        }
      }
    ],
    "resources": {
      "resources/node-aarch64-apple-darwin": "node-aarch64-apple-darwin",
      "resources/openclaw": "openclaw"
    }
  }
}
